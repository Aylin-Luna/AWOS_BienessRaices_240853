extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-indigo-600 Bienes
            span.font-normal.text-pink-500 Raíces
        
        .bg-white.shadow-2xl.rounded-3xl.p-10.max-w-md.mx-auto.text-center.border-t-4.border-purple-500
            
            //- Avatar de GitHub
            .flex.justify-center.mb-6
                if usuario.foto
                    img.h-32.w-32.rounded-full.border-4.border-purple-100.shadow-lg(src=usuario.foto alt="Foto de Perfil")
                else
                    .bg-gray-200.h-32.w-32.rounded-full.flex.items-center.justify-center
                        svg.h-16.w-16.text-gray-400(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")

            h2.text-3xl.font-bold.text-gray-800.mb-1= usuario.nombre
            p.text-indigo-600.font-medium.mb-6 Perfil de GitHub vinculado

            .bg-gray-50.rounded-2xl.p-6.mb-8.text-left
                .mb-4
                    p.text-xs.uppercase.text-gray-400.font-bold.mb-1 Correo electrónico
                    p.text-gray-700.font-semibold= usuario.email
                .mb-4
                    p.text-xs.uppercase.text-gray-400.font-bold.mb-1 ID de GitHub
                    p.text-gray-700.font-semibold= usuario.proveedorId
                div
                    p.text-xs.uppercase.text-gray-400.font-bold.mb-1 Estado de la cuenta
                    span.px-3.py-1.bg-green-100.text-green-700.rounded-full.text-xs.font-bold Directo desde GitHub

            .flex.flex-col.gap-3
                a.w-full.bg-indigo-600.text-white.font-bold.py-3.rounded-xl.shadow-lg.uppercase.hover_bg-indigo-700.transition-all(href="/" style="text-decoration:none;") Ir al Inicio
                
                form(method="POST" action="/auth/logout")
                    button.w-full.bg-white.text-rose-500.border.border-rose-200.font-bold.py-3.rounded-xl.uppercase.hover_bg-rose-50.transition-all(type="submit") Cerrar Sesión y Cambiar Cuenta