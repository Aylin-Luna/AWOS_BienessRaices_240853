extends ../layout/index

block contenido 
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-indigo-600  Bienes
            span.font-normal.text-black Raíces
        h2.text-center.text-2xl.font-normal.text-black Por favor ingresa cuidadosamente tus datos

        .mt-8.mx-auto.max-w-xl 
            .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
                form.space-y-5(method="POST" action="/auth/registro")
                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mt-2.font-bold(for="nombreUsuario") nombre completo:
                        input#nombreUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder= "p.e.: Obed Vargas Luna" name="nombreUsuario" type="text")

                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mt-2.font-bold(for="emailUsuario") correo electrónico:
                        input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder= "p.e.: usuario@dominio.com" name="emailUsuario" type="email")
                    
                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mt-2.font-bold(for="passwordUsuario") Contraseña:
                        div.relative
                            input#passwordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder= "Por lo menos 8 caracteres" name="passwordUsuario" type="password")
                            button.absolute.right-3.top-2.text-gray-400.cursor-pointer.toggle-password(type="button" data-target="#passwordUsuario")
                                svg.h-6.w-6(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.644C3.799 8.363 7.727 6 12 6c4.273 0 8.201 2.363 9.964 5.678a1.012 1.012 0 0 1 0 .644C20.201 15.637 16.273 18 12 18c-4.273 0-8.201-2.363-9.964-5.678Z")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z")

                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mt-2.font-bold(for="confirmacionUsuario") Confirmación de Contraseña:
                        div.relative
                            input#confirmacinUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder= "Repite la contraseña anterior" name="confirmacionUsuario" type="password")
                            button.absolute.right-3.top-2.text-gray-400.cursor-pointer.toggle-password(type="button" data-target="#confirmacinUsuario")
                                svg.h-6.w-6(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.644C3.799 8.363 7.727 6 12 6c4.273 0 8.201 2.363 9.964 5.678a1.012 1.012 0 0 1 0 .644C20.201 15.637 16.273 18 12 18c-4.273 0-8.201-2.363-9.964-5.678Z")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z")

                    input(class= "w-full bg-indigo-600 text-white hover:bg-purple-600 transition-colors font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase" type="submit" value= "Registrar Usuario")

                    div.flex.items-center.justify-between.pt-3
                        a(class="text-gray-500 text-sm hover:decoration-pink-400 hover:text-pink-600 hover:underline transition decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
                        a(class="text-gray-500 text-sm hover:decoration-pink-400 hover:text-pink-600 hover:underline transition decoration-2" href="/auth/olvide-password") ¿Olvidaste tu contraseña? Recuperala

block scripts 
    script.
        const buttons = document.querySelectorAll('.toggle-password');
        buttons.forEach(button => {
            button.addEventListener('click', () => {
                const target = document.querySelector(button.getAttribute('data-target'));
                const type = target.getAttribute('type') === 'password' ? 'text' : 'password';
                target.setAttribute('type', type);
                button.classList.toggle('text-indigo-600');
            });
        });