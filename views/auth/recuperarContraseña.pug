extends ../layout/index

block contenido 
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-indigo-600  Bienes
            span.font-normal.text-black Raíces
        h2.text-center.text-2xl.font-normal.text-black= pagina

        .mt-8.mx-auto.max-w-xl 
            .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
                form.space-y-5
                    div.px-5
                        label.block.text-sm.uppercase.text-gray-500.mt-2.font-bold(for="emailUsuario") correo electrónico:
                        input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder= "p.e.: usuario@dominio.com" name="emailUsuario" type="email")
                    
                    input(class= "w-full bg-indigo-600 text-white hover:bg-purple-600 transition-colors font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase" type="submit" value= "Enviar código de recuperación")

                    div.flex.items-center.justify-between.pt-3
                        a(class="text-gray-500 text-sm hover:decoration-pink-400 hover:text-pink-600 hover:underline transition decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
                        a(class="text-gray-500 text-sm hover:decoration-pink-400 hover:text-pink-600 hover:underline transition decoration-2" href="/auth/registro") ¿No tienes cuenta? Registrate