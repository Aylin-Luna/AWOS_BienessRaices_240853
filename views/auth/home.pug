extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-indigo-600 Bienes
            span.font-normal.text-pink-500 Raíces
        
        .bg-white.shadow-2xl.rounded-3xl.p-10.max-w-2xl.mx-auto.text-center.border-t-4.border-purple-500
            if usuario
                .flex.justify-center.mb-6
                    if usuario.proveedor === 'github'
                        .bg-gray-800.p-4.rounded-full.shadow-lg
                            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="48" height="48" fill="white")
                                path(d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12")
                    else if usuario.proveedor === 'google'
                        .bg-white.p-4.rounded-full.shadow-lg.border
                            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="48" height="48")
                                path(fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z")
                                path(fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z")
                                path(fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z")
                                path(fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z")

                h2.text-3xl.font-bold.text-gray-800.mb-2 ¡Hola, #{usuario.nombre}!
                p.text-gray-500.text-lg.mb-8 Has iniciado sesión correctamente con su cuenta de 
                    span.font-bold.capitalize.text-indigo-600= usuario.proveedor

                .grid.grid-cols-1.gap-4
                    a.w-full.bg-gradient-to-r.from-indigo-500.to-purple-500.text-white.font-bold.py-3.rounded-xl.shadow-lg.uppercase.hover_from-indigo-600.hover_to-purple-600.transition-all.duration-300(href="#" style="text-decoration:none;") Ir a Mis Propiedades
                    
                    form(method="POST" action="/auth/logout")
                        button.w-full.bg-white.border-2.border-gray-200.text-gray-500.font-bold.py-3.rounded-xl.uppercase.hover_bg-gray-50.hover_text-rose-500.hover_border-rose-200.transition-all.duration-300(type="submit") Cerrar Sesión
            else
                h2.text-2xl.font-bold.text-gray-800.mb-4 Bienvenido a Bienes Raíces
                p.text-gray-500.mb-8 Inicia sesión para gestionar tus propiedades.
                a.inline-block.bg-indigo-600.text-white.font-bold.py-3.px-10.rounded-xl.uppercase.hover_bg-indigo-700.transition-all(href="/auth/login" style="text-decoration:none;") Iniciar Sesión